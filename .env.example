# ============================================================
# JobFlow Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/jobtracker
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=jobtracker
PGHOST=db
PGPORT=5432

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production
SESSION_SECRET=change-this-too

# AI (optional - set LLM_ENABLED=true to use real LLM)
LLM_ENABLED=false
OPENAI_API_KEY=sk-...

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Service URLs (used by API Gateway)
AUTH_SERVICE_URL=http://auth-service:8001
JOB_SERVICE_URL=http://job-service:8002
PAYMENT_SERVICE_URL=http://payment-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004
ANALYTICS_SERVICE_URL=http://analytics-service:8005
AI_SERVICE_URL=http://ai-agent-service:8006

# AWS (for deployment)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# LocalStack (local AWS simulation)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_QUEUE_URL=http://localhost:4566/000000000000/jobflow-notifications

# Frontend
VITE_API_URL=http://localhost:8000
NODE_ENV=development
